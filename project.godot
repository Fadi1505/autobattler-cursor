; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LaneDefense3D"
run/main_scene="res://scenes/world/GameWorld.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/GameState.gd"
WaveDirector="*res://scripts/core/WaveDirector.gd"
SaveSystem="*res://scripts/core/SaveSystem.gd"
ProfileData="*res://scripts/core/ProfileData.gd"
MetaProgression="*res://scripts/meta/MetaProgression.gd"
BalanceTables="*res://scripts/data/BalanceTables.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

